#include <winres.h>
#include "resource.h"
#include "version.h"

/* Application icon. Lowest icon-resource ID becomes the .exe file icon
   shown by Windows Explorer. */
IDI_APP ICON "app.ico"

IDD_SETTINGS DIALOGEX 0, 0, 220, 100
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "WinPin Settings"
FONT 9, "Segoe UI", 400, 0, 1
BEGIN
    LTEXT         "&Hotkey to toggle pin on focused window:", -1, 10,  10, 200, 10
    CONTROL       "", IDC_HOTKEY, "msctls_hotkey32",
                  WS_TABSTOP | WS_BORDER,                          10,  24, 200, 14
    AUTOCHECKBOX  "Start with &Windows",        IDC_CHK_AUTOSTART, 10,  52, 200, 12
    DEFPUSHBUTTON "OK",                         IDOK,             110,  78,  50, 14
    PUSHBUTTON    "Cancel",                     IDCANCEL,         165,  78,  50, 14
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    APP_VERSION_MAJOR,APP_VERSION_MINOR,APP_VERSION_BUILD,0
 PRODUCTVERSION APP_VERSION_MAJOR,APP_VERSION_MINOR,APP_VERSION_BUILD,0
 FILEFLAGSMASK  0x3fL
 FILEFLAGS      0x0L
 FILEOS         VOS__WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Baltazar Studios, LLC"
            VALUE "FileDescription",  "WinPin - always-on-top window utility"
            VALUE "FileVersion",      APP_VERSION_STR4
            VALUE "InternalName",     APP_NAME
            VALUE "OriginalFilename", "WinPin.exe"
            VALUE "ProductName",      APP_NAME
            VALUE "ProductVersion",   APP_VERSION_STR4
            VALUE "LegalCopyright",   APP_COPYRIGHT " " APP_LICENSE
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
